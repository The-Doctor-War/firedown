{
  "manifest_version": 2,
  "version": "5.35",
  "browser_specific_settings": {
    "gecko": {
      "id": "parser@solarized.dev"
    }
  },
  "name": "Video parser",
  "description": "Parses media URLs from Vimeo, Twitter/X, Instagram, Threads, Facebook, Rumble, Bilibili.tv, Niconico, Kick, Twitch, Dailymotion, Apple Podcasts, and TikTok",
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "page-state-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons",
    "tabs",
    "cookies",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "*://*.instagram.com/*",
    "*://*.threads.com/*",
    "*://*.threads.net/*",
    "*://*.facebook.com/*",
    "*://*.fbcdn.net/*",
    "*://fb.watch/*",
    "*://rumble.com/*",
    "*://*.rumble.com/*",
    "*://www.bilibili.tv/*",
    "*://*.nicovideo.jp/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.vimeo.com/*",
    "*://*.kick.com/*",
    "*://*.twitch.tv/*",
    "*://*.ttvnw.net/*",
    "*://gql.twitch.tv/*",
    "*://clips.twitch.tv/*",
    "*://*.dailymotion.com/*",
    "*://geo.dailymotion.com/*",
    "*://*.dmcdn.net/*",
    "*://podcasts.apple.com/*",
    "*://amp-api.podcasts.apple.com/*",
    "*://amp-api-edge.podcasts.apple.com/*",
    "*://itunes.apple.com/*",
    "*://*.tiktok.com/*"
  ]
}