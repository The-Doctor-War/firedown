{
  "description": "Download webRequests",
  "manifest_version": 2,
  "browser_specific_settings": {
    "gecko": {
      "id": "downloader@solarized.dev"
    }
  },
  "name": "webRequest-downloads",
  "version": "2.18",
  "permissions": [
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "webNavigation",
    "cookies",
    "storage",
    "unlimitedStorage",
    "<all_urls>"
  ],

  "background": {
    "page": "background.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content-script.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["js/page-state-bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "web_accessible_resources": ["js/wasm-probe.js"]
}