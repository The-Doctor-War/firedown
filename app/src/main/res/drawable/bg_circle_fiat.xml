<?xml version="1.0" encoding="utf-8"?>
<!--
    Circle behind the coffee-cup icon for the fiat row. Sits on the
    theme's tertiary container so it reads as the third rail (after
    Lightning's primary and Bitcoin's secondary), keeping the three
    cards visually distinct without hard-coding brand colors.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="?attr/colorTertiaryContainer" />
</shape>
