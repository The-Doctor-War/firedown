<?xml version="1.0" encoding="utf-8"?>
<!--
    Rounded-square frame behind the popup identity favicon.
    Matches the DuckDuckGo-style site-header treatment: a 40dp
    surface-variant tile padded down to a 24dp favicon, so any
    favicon (square, transparent, monochrome) reads as a single
    coherent identity chip rather than floating on the sheet.

    The sheet itself paints colorSurfaceContainerHigh
    (dialog_rounded_top.xml). In the standard theme that's
    #E9E7EA (light) / #292A2C (dark); we pick surfaceBright
    (#FBF9FB light / #39393B dark), which sits ~16–18 luminance
    units brighter than the sheet bg in both modes and reads as a
    raised tile. The obvious sibling, colorSurfaceVariant, was too
    close to the sheet bg in light mode (#E1E2E9 vs #E9E7EA, ~5
    units apart) and the tile disappeared.

    Incognito sheets paint a purple container_high (#4a2779) instead
    — there a gray-blue tone would clash with the purple, so the
    incognito sheet theme remaps popupFaviconBackgroundColor to
    incognito_surface_container_highest (#553090), which stays in the
    purple family while still reading as a tile.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="?attr/popupFaviconBackgroundColor" />
    <corners android:radius="10dp" />
</shape>
