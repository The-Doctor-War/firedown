<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Strong dark band at the bottom edge fading up to transparent so the
         overlaid title + metadata stay legible over bright thumbnail art
         (e.g. the yellow "OTRA TURRA" frames). angle=90 runs bottom→top. -->
    <gradient
        android:angle="90"
        android:startColor="#EE000000"
        android:centerColor="#99000000"
        android:endColor="@android:color/transparent" />
</shape>
