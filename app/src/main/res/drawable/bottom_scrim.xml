<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark at the bottom edge fading up to transparent, so the overlaid
         title + metadata stay legible against bright thumbnail art. angle=90
         runs the gradient bottom→top (start at the bottom). -->
    <gradient
        android:angle="90"
        android:startColor="#CC000000"
        android:centerColor="#66000000"
        android:endColor="@android:color/transparent" />
</shape>
