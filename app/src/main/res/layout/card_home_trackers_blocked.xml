<?xml version="1.0" encoding="utf-8"?>
<!--
  Home page 'Trackers blocked' shelf card. Same shape as the Downloads
  and Safe Folder cards — surfaceContainerHigh card, 40dp tonal chip,
  title + subtitle — so the three reads as equal-weight destinations.
  Peach chip (secondaryContainer) so it doesn't fight Downloads (coral)
  or Safe Folder (raspberry) for tonal identity.

  Subtitle is the cumulative count formatted via NumberFormat in
  HomeFragment; card stays visible from first run so the metric is
  always discoverable even at zero. Tap → Settings → Enhanced
  Tracking Protection (the surface where the user can tune what's
  being blocked).
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/home_trackers_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp">

        <FrameLayout
            android:id="@+id/home_trackers_chip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_icon_container_secondary">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/home_trackers_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_shield_24"
                app:tint="?attr/colorOnSecondaryContainer" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/home_trackers_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/home_trackers_title"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/home_trackers_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="12,345 since install" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
