<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical">

    <include
        android:id="@+id/clipboard_view"
        layout="@layout/fragment_autocomplete_clipboard_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/address_bar_margin"
        android:layout_marginEnd="@dimen/address_bar_margin"
        android:layout_marginTop="6dp"
        android:visibility="gone" />


    <!--
        Single Material 3 container card holding the suggestion list. It
        wraps its content (the RecyclerView is wrap_content too) so the card
        grows and shrinks with the number of suggestions instead of showing
        a tall fixed panel under the address bar. The result set is small and
        capped (search/tab/history limits), so wrap_content never overflows
        in practice. The card is GONE while empty (its only child drives the
        content) so no blank surface shows; showEmpty()/hideAll() on
        search_view stay the source of truth and the card mirrors them. Rows
        are flat inside — the card supplies the one rounded surface (replaces
        the old per-row cards whose corners were morphed by position to fake
        a single container).
    -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/address_bar_margin"
        android:layout_marginEnd="@dimen/address_bar_margin"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHighest"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <com.solarized.firedown.autocomplete.AutoCompleteRecyclerView
            android:id="@+id/search_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:overScrollMode="never"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </com.google.android.material.card.MaterialCardView>


</LinearLayout>