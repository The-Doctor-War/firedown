<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/item"
        style="@style/Widget.Material3.CardView.Elevated"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:layout_constraintDimensionRatio="16:10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="8dp"
        app:strokeColor="@color/transparent"
        app:strokeWidth="2dp">

        <!-- Thumbnail -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:duplicateParentState="true"
            android:scaleType="centerCrop" />

        <!-- Top scrim for the more button's readability against bright art. -->
        <View
            android:id="@+id/dim_view"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="@drawable/top_scrim"
            android:elevation="12dp" />

        <!-- Bottom info block: a gradient scrim carrying the title + a single
             metadata row. Replaces the old bottom corner chip cluster that had
             no title and overflowed in 2-column width. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bottom_scrim"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/file_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="2"
                tools:text="Soto Ivars: CUANDO ME RECIBEN ASÍ, SUELEN SALIR…" />

            <!-- Metadata row, one consistent hierarchy for every media kind:
                 a decorated mime CHIP (identity) followed by subtle scrim TEXT
                 for its single key fact — duration for audio/video, dimensions
                 for image/SVG — then a primary-tinted CC affordance when
                 captions exist. Clustered at the start (no weighted spacer), so
                 a video reads "[VIDEO] 19:34 · CC 2" and an image reads
                 "[IMAGE] 73×73". Only the mime tag carries a background, which
                 mirrors list mode; attributes stay quiet so the photo leads.
                 Quality/Adaptive stays out of the tile (it overflows the narrow
                 cell; it's in the download sheet). -->
            <LinearLayout
                android:id="@+id/tag_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/mime_text"
                    style="@style/MimePrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    tools:text="VIDEO" />

                <!-- Duration (AV) / dimensions (image, SVG) — the item's single
                     key fact. Subtle scrim text, NOT a chip: only the mime tag
                     is decorated (it's the identity, and maps to the filter
                     rail), matching list mode. Attributes recede so the photo
                     and the type lead. Duration and dimensions share the slot —
                     never both on one tile. -->
                <TextView
                    android:id="@+id/tag_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:singleLine="true"
                    android:textSize="11.5sp"
                    android:textColor="#E0FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:visibility="gone"
                    tools:text="53:25"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tag_quality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textSize="11.5sp"
                    android:textColor="#E0FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:visibility="gone"
                    tools:text="320 × 180"
                    tools:visibility="visible" />

                <!-- "·" before CC — shown by the adapter only when a preceding
                     fact is visible (mirrors list mode's separator logic). -->
                <TextView
                    android:id="@+id/tag_cc_separator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginEnd="5dp"
                    android:text="@string/separator"
                    android:textSize="11sp"
                    android:textColor="#73FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <!-- CC stays primary-tinted text, not a chip: it's an
                     affordance ("captions available"), the one fact that
                     changes what you can download — list mode tints it the
                     same way. -->
                <TextView
                    android:id="@+id/tag_cc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:singleLine="true"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFB3B1"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:visibility="gone"
                    tools:text="CC 52"
                    tools:visibility="visible" />

            </LinearLayout>

        </LinearLayout>

        <!-- Variant / more button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/item_download_more"
            style="@style/Theme.FireDown.More.Button"
            android:layout_gravity="top|end"
            app:icon="@drawable/ic_baseline_more_vert_24" />

        <!-- Selection indicator -->
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/item_download_more_checked"
            app:tint="?attr/colorPrimaryContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:padding="@dimen/button_icons_padding"
            android:visibility="gone"
            app:srcCompat="@drawable/ic_baseline_check_circle_24" />

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
