<?xml version="1.0" encoding="utf-8"?>
<!-- Single vertical LinearLayout: the previous design wrapped the
     toolbar + filter chips in a second LinearLayout that carried only
     elevation="0dp" (no actual elevation) and forced an extra measure
     pass on every inflation. Flattened. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.FireDown.Toolbar"
        app:navigationIconTint="?attr/colorOnSurface"
        app:popupTheme="@style/Theme.FireDown.Popup"
        app:title="@string/navigation_captured" />

    <include
        layout="@layout/fragment_dialog_browser_options_list_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- "Still scanning" banner. Shown (debounced) above existing captures
         while an inspect task is in flight, so a slow capture (e.g. an HLS
         master fetch) doesn't read as "nothing was captured". Hidden by
         default; the empty list uses the LCEE loading state instead. -->
    <LinearLayout
        android:id="@+id/capture_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="?attr/colorSurfaceVariant">

        <ProgressBar
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:indeterminate="true"
            android:indeterminateTint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/capture_banner_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:text="@string/capture_scanning" />
    </LinearLayout>

    <com.solarized.firedown.ui.LCEERecyclerView
        android:id="@+id/list_recycler_lcee"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>