<?xml version="1.0" encoding="utf-8"?>
<!-- Single vertical LinearLayout: the previous design wrapped the
     toolbar + filter chips in a second LinearLayout that carried only
     elevation="0dp" (no actual elevation) and forced an extra measure
     pass on every inflation. Flattened. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.FireDown.Toolbar"
        app:navigationIconTint="?attr/colorOnSurface"
        app:popupTheme="@style/Theme.FireDown.Popup"
        app:title="@string/navigation_captured" />

    <include
        layout="@layout/fragment_dialog_browser_options_list_options"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <!-- One-shot help banner: shown only when the list is NON-empty (the empty
         state already explains this) until the user taps or dismisses it. Tapping
         the body opens the same help as the toolbar Help item; the X dismisses.
         Gone by default; visibility is driven from BrowserOptionFragment. -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/capture_help_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/list_spacing"
        android:layout_marginEnd="@dimen/list_spacing"
        android:layout_marginTop="@dimen/list_spacing"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="@dimen/card_radius"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/list_spacing_search"
            android:paddingEnd="4dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_help_24"
                android:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/capture_help_banner_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/list_spacing_search"
                android:text="@string/capture_help_banner"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <ImageButton
                android:id="@+id/capture_help_banner_dismiss"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/task_dismiss"
                android:src="@drawable/ic_baseline_close_24"
                android:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.solarized.firedown.ui.LCEERecyclerView
        android:id="@+id/list_recycler_lcee"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>