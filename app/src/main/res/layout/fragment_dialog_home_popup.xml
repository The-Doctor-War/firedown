<?xml version="1.0" encoding="utf-8"?>
<!--
    Home "more" popup sheet.

    Card removed, rows sit flat on the sheet surface. No section
    rules — with only two-or-three rows the structure is obvious,
    and the destructive Quit row marks itself via colorPrimary
    text + tint.

    Incognito home reuses this layout: the fragment swaps the History
    row's icon, label, and dispatched id over to Downloads.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="8dp">

    <include
        layout="@layout/dialog_drag_handle" />


    <!-- Row order is Downloads → Safe Folder → History so each mode reads
         consistently with History last, above Settings:
           regular  : Safe Folder, History   (Downloads GONE)
           incognito: Downloads, History      (Safe Folder GONE)
         Visibility is toggled in PopupHomeSheetDialogFragment. -->


    <!-- Downloads — incognito home only (regular home already has a
         Downloads card; incognito home does not). GONE by default; the
         fragment shows it under incognito. -->
    <LinearLayout
        android:id="@+id/popup_downloads"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/navigation_downloads"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/download_24"
            app:drawableTint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>


    <!-- Safe Folder — regular home only. (Incognito downloads already land
         in the Safe Folder, so a dedicated entry there would be redundant.) -->
    <LinearLayout
        android:id="@+id/popup_vault"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/home_vault_button"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/ic_lock_24"
            app:drawableTint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>


    <!-- History — both modes. Under incognito it opens the saved
         regular-session history read-only (incognito records none),
         with the incognito flag passed through. -->
    <LinearLayout
        android:id="@+id/popup_history"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/popup_history_text"
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/library_history"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/ic_history_24"
            app:drawableTint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>


    <!-- Settings. -->
    <LinearLayout
        android:id="@+id/popup_settings"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/browser_menu_settings"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/ic_settings_24"
            app:drawableTint="?attr/colorOnSurfaceVariant" />

    </LinearLayout>


    <!-- Destructive Quit — GONE unless SETTINGS_QUIT_PREF is on.
         colorPrimary text + drawable tint is what differentiates it. -->
    <LinearLayout
        android:id="@+id/popup_quit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            style="@style/TextAppearance.Material3.TitleMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:drawablePadding="16dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/delete_browsing_data_on_quit_action"
            android:textColor="?attr/colorPrimary"
            android:textSize="15sp"
            app:drawableStartCompat="@drawable/ic_logout_24"
            app:drawableTint="?attr/colorPrimary" />

    </LinearLayout>

</LinearLayout>
