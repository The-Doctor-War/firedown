<?xml version="1.0" encoding="utf-8"?>
<!--
    Per-site security / protection sheet.

    Layout vocabulary mirrors fragment_dialog_trackers_info.xml so the
    two sheets read as siblings on the browser surface — three equal
    stat cards near the top, then small-caps section headers above
    flat row lists. Earlier this sheet used a filled MaterialCard with
    internal 1dp dividers; data-display + control hybrids read better
    as labelled sections than as one unlabelled grouped list.

    Sections (top → bottom):
      1. Site identity header (favicon + host + URL) — anchors the
         sheet to a specific site.
      2. Stats row — Ads blocked / Trackers blocked / Data saved.
         All three are per-page numerics. Data saved is computed in
         the fragment as (adsBlocked + trackersBlocked) × 50_000
         bytes, matching the formula HomeFragment and the
         TrackersInfoSheet use for the same display.
      3. PROTECTION section — Block ads toggle, Tracking protection
         toggle (with subtext describing the current state).
      4. THIS PAGE section (header + row both visibility="gone" until
         ETP is on for this site AND blocked-tracker count > 0). Row
         drills into the per-host blocked-tracker detail sheet.
      5. MANAGE section — Connection (drill-down to cert details),
         Clear browsing data (drill-down).

    Outer LinearLayout is left unpadded because
    BaseBottomSheetDialogFragment's window-insets listener applies
    padding directly to mView (same pattern as the TrackersInfoSheet
    layout).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <include layout="@layout/dialog_drag_handle" />


    <!--
        Site identity. Stays at the top as a distinct block above the
        protection controls — it's the site anchor, not a control, so
        it sits in its own hierarchy level.
    -->
    <LinearLayout
        android:id="@+id/host_domain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/host_image"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/host"
                style="@style/TextAppearance.Material3.TitleSmall.Emphasized"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="CNN" />

            <TextView
                android:id="@+id/host_url"
                style="@style/TextAppearance.Material3.BodyMedium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                tools:text="www.cnn.com" />

        </LinearLayout>

    </LinearLayout>


    <!--
        Body container — wrapped in a NestedScrollView so the sheet's
        full content (stats + PROTECTION toggles + MANAGE drill-downs)
        stays reachable in landscape and on short screens, where the
        bottom-sheet height would otherwise clip the MANAGE section
        off the bottom. The drag-handle + site-identity rows above
        stay outside the scroller — that's the bottom-sheet drag
        zone, scroll happens in here. paddingHorizontal mirrors
        TrackersInfoSheet (24dp) so the two sheets line up.
    -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp">


        <!--
            Stats row. Two equal cards using weight=1 with an 8dp Space
            between. Same Widget.Material3.CardView.Filled tonal style
            the TrackersInfoSheet uses for its three-card row, but
            scoped to the per-page actionable counters only — Ads and
            Trackers each carry a tappable list drill-down beneath
            them. A previous iteration had a third "Data saved" card
            here, but it was a derived stat (count × ~50KB) with no
            list to drill into, so it sat alongside two tappable peers
            as a non-tappable look-alike — the worst of both worlds.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!--
                Ads card. Tap drills into BlockedAdsDetailDialogFragment
                which lists every uBlock-blocked host on the current
                page. selectableItemBackground gives ripple feedback so
                the user can tell the card is interactive even though
                it carries no chevron.
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ads_stat_card"
                style="@style/TrackersInfoStatCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout style="@style/TrackersInfoStatBody">

                    <TextView
                        android:id="@+id/ads_counter"
                        style="@style/TrackersInfoStatValue"
                        tools:text="24" />

                    <TextView
                        style="@style/TrackersInfoStatLabel"
                        android:text="@string/security_stat_ads_blocked" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Space
                android:layout_width="8dp"
                android:layout_height="match_parent" />

            <!--
                Trackers card. Tap drills into
                BlockedTrackersDetailDialogFragment (the existing per-
                category sheet). Same ripple foreground as the Ads card.
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/trackers_stat_card"
                style="@style/TrackersInfoStatCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout style="@style/TrackersInfoStatBody">

                    <TextView
                        android:id="@+id/trackers_counter"
                        style="@style/TrackersInfoStatValue"
                        tools:text="14" />

                    <TextView
                        style="@style/TrackersInfoStatLabel"
                        android:text="@string/security_stat_trackers_blocked" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


        <!-- ── PROTECTION ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="4dp"
            android:letterSpacing="0.08"
            android:text="@string/security_section_protection"
            android:textAllCaps="true"
            android:textAppearance="?attr/textAppearanceTitleSmallEmphasized"
            android:textColor="?attr/colorOnSurfaceVariant" />


        <!--
            Block ads — toggle row. The row's whole surface is the
            click target; the switch carries duplicateParentState so
            tapping anywhere in the row flips it, matching how the
            popup's Desktop site row behaves.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ads_click_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/security_block_ads"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/ads_toogle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>


        <!--
            Tracking protection — toggle row with a subtitle line for
            the "if something looks broken, try turning it off" hint.
            Subtitle copy is swapped in updateTrackingUI based on the
            current toggle state.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/tracking_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_shield_24"
                app:tint="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_tracking_protection"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tracking_subtext"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:maxLines="2"
                    android:text="@string/protection_panel_etp_toggle_enabled_description_2"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />

            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/tracking_toogle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp" />

        </LinearLayout>


        <!-- ── MANAGE ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:letterSpacing="0.08"
            android:text="@string/security_section_manage"
            android:textAllCaps="true"
            android:textAppearance="?attr/textAppearanceTitleSmallEmphasized"
            android:textColor="?attr/colorOnSurfaceVariant" />


        <!-- Connection — drill-down to cert details. Icon and label
             flip between secure / insecure variants in the fragment. -->
        <LinearLayout
            android:id="@+id/host_secure"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/host_secure_text"
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawablePadding="16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/connection_secure"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/encryption_light_24"
                app:drawableTint="?attr/colorOnSurfaceVariant" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_chevron_right_24"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>


        <!-- Clear cookies / site data for this hostname. -->
        <LinearLayout
            android:id="@+id/host_clear"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                style="@style/TextAppearance.Material3.TitleMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawablePadding="16dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="@string/settings_clear_browsing"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="15sp"
                app:drawableStartCompat="@drawable/ic_baseline_delete_24"
                app:drawableTint="?attr/colorOnSurfaceVariant" />

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:contentDescription="@null"
                app:srcCompat="@drawable/ic_chevron_right_24"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
