<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/item"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintDimensionRatio="16:10"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:cardCornerRadius="8dp"
        app:strokeWidth="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Top scrim (FINISHED only) -->
            <View
                android:id="@+id/top_scrim"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/top_scrim"
                android:elevation="12dp"
                android:visibility="gone"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Thumbnail. match_parent both ways inside the 16:10
                 ratio card — adjustViewBounds is intentionally absent
                 because the dimensions are fixed; the platform would
                 still evaluate it on every measure. -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/mask_image_rounded"
                android:contentDescription="@null"
                android:duplicateParentState="true"
                android:outlineProvider="background"
                android:scaleType="centerCrop" />

            <!-- Progress overlay on thumbnail (PROGRESS only) -->
            <com.solarized.firedown.ui.ProgressOverlayView
                android:id="@+id/image_progress"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Bottom info block: a gradient scrim carrying the title + a
                 metadata row + status, mirroring the Captured grid. The scrim
                 is the block's background (always present); the adapter toggles
                 the individual children per download state. Left-aligned and
                 full-width like Captured. -->
            <LinearLayout
                android:id="@+id/bottom_block"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bottom_scrim"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"
                android:paddingTop="14dp"
                android:paddingBottom="7dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/file_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    tools:text="Latorre, sobre Zapatero: Todo era una fantasía…" />

                <!-- Metadata row: a decorated mime CHIP (identity) followed by
                     subtle scrim TEXT for the duration — only mime carries a
                     background, matching the Captured grid. -->
                <LinearLayout
                    android:id="@+id/row_mime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/mime_text"
                        style="@style/MimePrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="4dp"
                        android:paddingRight="4dp"
                        tools:text="mp4" />

                    <TextView
                        android:id="@+id/mime_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:singleLine="true"
                        android:textSize="11.5sp"
                        android:textColor="#E0FFFFFF"
                        android:shadowColor="#80000000"
                        android:shadowDx="0"
                        android:shadowDy="1"
                        android:shadowRadius="2"
                        android:visibility="gone"
                        tools:text="00:10" />

                </LinearLayout>

                <!-- ERROR / QUEUED status. FINISHED's "size · date" label is
                     list-only; the grid leans on title + mime instead. -->
                <TextView
                    android:id="@+id/status_text"
                    style="@style/TextAppearance.Material3.BodySmall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:textColor="?attr/colorPrimaryContainer"
                    android:visibility="gone"
                    tools:text="@string/error_check_internet_connection" />

            </LinearLayout>

            <!-- Action button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/item_download_action"
                style="@style/Theme.FireDown.More.Button"
                app:icon="@drawable/ic_baseline_more_vert_24"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/image" />

            <!-- Selection indicator -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/item_download_selected"
                style="@style/Theme.FireDown.Selected.Button"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_baseline_check_circle_24" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>