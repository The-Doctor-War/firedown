<?xml version="1.0" encoding="utf-8"?>
<!--
    Bookmark edit screen.

    Bare form layout matching the rest of the app's form surfaces
    (preference inputs, lock screen, vault) — no MaterialCard
    wrappers around the inputs or actions. Earlier iterations grouped
    everything into surfaceContainer cards, which looked closer to
    the Home dashboard cards than the form screens this fragment
    actually sits next to.

    Layout (top → bottom):
      • App bar with up-navigation + "Open in browser" / "Share"
        menu icons (standard detail-screen secondary-action slot).
      • Identity header — favicon + title + URL preview. Lives at
        the top as a bare block, no card chrome; updates live as the
        user edits the fields below.
      • Title TextInputLayout
      • URL TextInputLayout
      • Primary "Save" button (enabled when both fields are non-empty
        and the URL parses).
      • Destructive "Delete bookmark" text button (colorError).

    Fields are editable from entry; no view-mode / edit-mode toggle.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="true"
        app:liftOnScrollTargetViewId="@+id/nested">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:theme="@style/ThemeOverlay.FireDown.Toolbar"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="?attr/colorOnSurface"
            app:popupTheme="@style/Theme.FireDown.Popup"
            app:title="@string/navigation_web_bookmarks_edit" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="fill_vertical"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <!-- ── Identity header (bare, unwrapped) ───────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="30dp"
                android:paddingTop="20dp"
                android:paddingBottom="8dp">

                <!--
                    No app:tint. The fallback ic_bookmark_24 vector
                    carries its own android:tint so the placeholder
                    reads themed; once Glide swaps in a real favicon
                    bitmap, an ImageView-level tint would paint over
                    its colours and flatten the loaded icon to one
                    shade of grey.
                -->
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/edit_favicon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_popup_chip_neutral"
                    android:contentDescription="@null"
                    android:padding="6dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_bookmark_24" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/edit_title_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceTitleSmall"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/edit_url_preview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </LinearLayout>


            <!-- ── Inputs (bare TextInputLayouts) ──────────────────── -->
            <com.solarized.firedown.ui.LoginPanelTextInputLayout
                android:id="@+id/title_text_input_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="30dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/title_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/bookmark_name"
                    android:imeOptions="actionNext"
                    android:singleLine="true"
                    android:textSize="16sp" />
            </com.solarized.firedown.ui.LoginPanelTextInputLayout>

            <com.solarized.firedown.ui.LoginPanelTextInputLayout
                android:id="@+id/host_text_input_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="30dp"
                app:endIconMode="none">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/host_field"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/login_host"
                    android:imeOptions="actionDone"
                    android:inputType="textWebEditText"
                    android:singleLine="true"
                    android:textSize="16sp" />
            </com.solarized.firedown.ui.LoginPanelTextInputLayout>


            <!-- ── Save (primary) ──────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_button"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                android:layout_marginTop="30dp"
                android:layout_marginEnd="30dp"
                android:padding="12dp"
                android:text="@string/prompt_save_confirmation" />


            <!-- ── Delete (destructive low-emphasis) ───────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/delete_button"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="30dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="30dp"
                android:layout_marginBottom="20dp"
                android:padding="12dp"
                android:stateListAnimator="@null"
                android:text="@string/bookmark_delete_action"
                android:textColor="?attr/colorError" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
